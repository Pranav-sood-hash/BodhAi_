# Environment Variables for BodhAI

# Groq API Configuration
# Get your free API key from: https://console.groq.com
# This is required for AI features (Voice Assistant, Study Mode, Code Helper)
GROQ_API_KEY=gsk_your_api_key_here

# Optional: Public Builder.io API Key (if using Builder.io features)
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__

# Optional: Custom ping message for /api/ping endpoint
PING_MESSAGE="ping pong"
